#include <stdio.h>

int main() {
    int arr[5] = {1, 2, 3, 4, 5};
    int n = 5;
    int i, new_val, index;

    printf("Enter new no: ");
    scanf("%d", &new_val);
    printf("Enter index: ");
    scanf("%d", &index);

    for (i = n; i > index; i--) {
        arr[i] = arr[i - 1];
    }
    n++;
    arr[index] = new_val;

    for (i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    return 0;
}
