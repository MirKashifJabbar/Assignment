#include<stdio.h>
int main(){
    int size,i;
    printf("Enter the size of array: ");
    scanf("%d",&size);

    int arr[size];
    printf("Enter the elements of array: ");
    for(i=0;i<size;i++){
        scanf("%d",&arr[i]);
    }
    int n =size;
    int temp;
    for(i=0;i<size/2;i++,n--){
        temp=arr[i];
        arr[i]=arr[n-1];
        arr[n-1]=temp;
    }
    printf("The array in reverse order is: ");
    for(i=0;i<size;i++){
        printf("%d ",arr[i]);
    }
    return 0;
}
