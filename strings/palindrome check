#include <stdio.h>
#include <string.h>

int main() {
    char str [50];

    printf("Enter your word: ");
    scanf("%49s",str);

    int len= strlen(str);
    int i,j=0;
    char revstr[len +1];

    for(i=len-1;i>=0;i--){

     revstr[j]=str[i];
     j++;
    }
revstr[j]='\0';


if(strcmp(str,revstr)==0){
    printf(
        "the given word is a palindrome");

}else{
    printf("The given word is not a palindrome");
}



    return 0;
}
