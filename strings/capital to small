#include <stdio.h>
#include <string.h>

int main(){
char str[40];
int i;
printf("Enter your word: ");
    scanf("%s",str);
    int len=strlen(str);
    for(i=0;i<len;i++){
        if(str[i]>='A' && str[i]<='Z'){
            str[i]=str[i]+32;
        }
    }
printf("The capital word is:%s\n",str);

return 0;
}
